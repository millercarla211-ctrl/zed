      "preview_anatomy": [
        "layout-items"
      ]
    },
    {
      "generator_id": "flex-layout-editor",
      "class_template": "flex items-center justify-between gap-[{gap}px]",
      "css_template": "display: flex;\nalign-items: center;\njustify-content: space-between;\ngap: {gap}px;",
      "preview_kind": "layout-items",
      "preview_anatomy": [
        "layout-items"
      ]
    },
    {
      "generator_id": "container-query-breakpoint-editor",
      "class_template": "@container @md:grid @md:grid-cols-{columns}",
      "css_template": "container-type: inline-size;\ncontainer-name: dx-style-preview;\n/* @container dx-style-preview (width >= 28rem) { grid-template-columns: repeat({columns}, minmax(0, 1fr)); } */",
      "preview_kind": "layout-items",
      "preview_anatomy": [
        "layout-items"
      ]
