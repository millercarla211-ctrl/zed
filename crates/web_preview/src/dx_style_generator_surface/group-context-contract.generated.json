{
  "schema": "dx.style.grouped-class-web-preview-context",
  "schema_version": 1,
  "scope": "read-only grouped-class cursor context for Zed Web Preview generator surfaces",
  "active_context_schema": "zed.dx_style.active_context.v1",
  "fixture_path": "fixtures/grouped-class-web-preview-context.json",
  "source_mutation_enabled": false,
  "supported_token_shapes": [
    "alias()",
    "alias(atomic utilities)",
    "@alias(atomic utilities)",
    "static atomic utility list"
  ],
  "group_call_syntax_values": [
    "alias_reference",
    "inline_utilities",
    "source_declaration",
    "static_atomic_utility_list"
  ],
  "group_call_status_values": [
    "alias_reference",
    "alias_reference_expanded",
    "inline_group_declaration",
    "source_group_declaration",
    "atomic_list_candidate"
  ],
  "group_call_status_by_syntax": [
    {
      "syntax": "alias_reference",
      "statuses": [
        "alias_reference",
        "alias_reference_expanded"
      ]
    },
    {
      "syntax": "inline_utilities",
      "statuses": [
        "inline_group_declaration"
      ]
    },
    {
      "syntax": "source_declaration",
      "statuses": [
        "source_group_declaration"
      ]
    },
    {
      "syntax": "static_atomic_utility_list",
      "statuses": [
        "atomic_list_candidate"
      ]
    }
  ],
  "context_fields": [
    "group_context.schema",
    "group_context.status",
    "group_context.alias",
    "group_context.syntax",
    "group_context.utilities",
    "group_context.utility_count",
    "group_context.expansion_status",
    "group_context.candidate_token_count",
    "group_context.source_state",
    "group_context.requires_registry_receipt",
    "group_context.source_owned",
    "group_context.can_expand_inline",
    "group_context.registry_receipt"
  ],
  "max_alias_bytes": 128,
  "max_utility_count": 32,
  "max_utility_bytes": 256,
  "candidate_min_utility_count": 4,
  "requires_project_group_registry_for_alias_reference": true
}
